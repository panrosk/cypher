{
  "productName": "cypher",
  "version": "0.0.0",
  "identifier": "com.cypher.dev",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "cypher",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/favicon-32.png",
      "icons/favicon-128.png",
      "icons/favicon-228.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
